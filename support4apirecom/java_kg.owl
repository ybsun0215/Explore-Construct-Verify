    <rdf:object rdf:resource="http://example.org/java-kg/individual/stepafter"/>
    <prop:relationInstance>executes</prop:relationInstance>
    <prop:sourceText>when the process() method of the subclass is called the full process is executed including the stepbefore() and stepafter() of the abstract superclass and the action() method of the subclass</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc209dc54b1414dc29e1ef6379a7eeec1">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/tailmap%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/headmap"/>
    <prop:relationInstance>similar to</prop:relationInstance>
    <prop:sourceText>the tailmap() method is similar to the headmap() method, except that tailmap() returns all elements that are equal to or higher than the given parameter element.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N54a9410f02d54914b069f1a19dd1a0ce">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/select%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/select"/>
    <prop:relationInstance>returns</prop:relationInstance>
    <prop:sourceText>if you call select() and it returns 1 because one channel has become ready, and you call select() one more time, and one more channel has become ready, it will return 1 again.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nfcf5f17b75a64108bcb9d510f8425e3f">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
