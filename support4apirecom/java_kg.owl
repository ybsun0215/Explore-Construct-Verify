  <rdf:Description rdf:nodeID="N56e632fdc53345fab7ec432c533778ad">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/getandincrement%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/incrementandget"/>
    <prop:relationInstance>works like</prop:relationInstance>
    <prop:sourceText>the methods getandincrement() and incrementandget() works like getandadd() and addandget() but just add 1 to the value of the atomiclong.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N67f200fc5215494aacea055acfbdd65b">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/getandincrement%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/incrementandget"/>
    <prop:relationInstance>returns the value of the element before it is incremented</prop:relationInstance>
    <prop:sourceText>the getandincrement() method does the same as the incrementandget() method, except the getandincrement() method returns the value of the element before it is incremented.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N4744bff769714c5bb158f955d7367c77">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/wait%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/notify"/>
    <prop:relationInstance>calls</prop:relationInstance>
    <prop:sourceText>if instead each thread calls wait() on a separate object, so that only one thread has called wait() on each object, the lock class can decide which of these objects to call notify() on, thereby effectively selecting exactly what thread to awaken.</prop:sourceText>
  </rdf:Description>
