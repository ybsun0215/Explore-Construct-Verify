    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/action"/>
    <prop:relationInstance>executed</prop:relationInstance>
    <prop:sourceText>when the process() method of the subclass is called, the full process is executed, including the stepbefore() and stepafter() of the abstract superclass, and the action() method of the subclass.</prop:sourceText>
  </rdf:Description>
