    <prop:sourceText>the floor() method does the opposite of the ceiling() method, meaning it returns the greatest element that is less than or equal to the given parameter value.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N2e1b381da24c40bbbb2e798b3be83941">
