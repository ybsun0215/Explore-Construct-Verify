    <prop:sourceText>you do so by calling the cipher update() or dofinal() methods.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Naff35e33a4764dfe8ce22a37201d86b5">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
