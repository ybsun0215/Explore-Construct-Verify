  </rdf:Description>
  <rdf:Description rdf:nodeID="N471e93f7d735407991b245063b8bd5b9">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/notifyall%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/wait"/>
    <prop:relationInstance>must obtain the lock on the monitor object in turn before exiting</prop:relationInstance>
    <prop:sourceText>if multiple threads are awakened using notifyall() only one awakened thread at a time can exit the wait() method, since each thread must obtain the lock on the monitor object in turn before exiting wait().</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6b794ae154644c24bcd35fc80dd19316">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
