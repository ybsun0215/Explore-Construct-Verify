    <rdfs:label>poll</rdfs:label>
    <prop:entityType>Method</prop:entityType>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N91fe12aff7664a03ba091520b914c5ee">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/filevisitor"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/IMPLEMENTATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/walkfiletree"/>
    <prop:relationInstance>implementation</prop:relationInstance>
    <prop:sourceText>you have to implement the filevisitor interface yourself, and pass an instance of your implementation to the walkfiletree() method.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6c0336bbcf754d109128c06af5f9b9b9">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/process%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/stepbefore"/>
    <prop:relationInstance>executes</prop:relationInstance>
    <prop:sourceText>when the process() method of the subclass is called the full process is executed including the stepbefore() and stepafter() of the abstract superclass and the action() method of the subclass</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N2d1102004cc14f6a8a43fabfc2bda982">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/wait%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/notify"/>
    <prop:relationInstance>signals</prop:relationInstance>
    <prop:sourceText>remember, that even if the 4 threads call wait() and notify() on the same shared string instance, the signals from the dowait() and donotify() calls are stored individually in the two mywaitnotify instances.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5692a7bb095246ee97818c12ae8cf6a1">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/dofinal%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/PREFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/doupdate"/>
    <prop:relationInstance>favored_over</prop:relationInstance>
    <prop:sourceText>to decrypt data you would have passed cipher text (encrypted data) into the dofinal() or doupdate() method instead.</prop:sourceText>
  </rdf:Description>
