    <prop:relationInstance>uses</prop:relationInstance>
    <prop:sourceText>here is a modified version of mysignal called mywaitnotify that uses wait() and notify()</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nad0cb00a7f6d49a4b19894a446ecfed7">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
