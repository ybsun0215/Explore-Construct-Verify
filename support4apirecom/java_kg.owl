  </rdf:Description>
  <rdf:Description rdf:nodeID="Ncb494b4ada334e8cb9f37cc613877cd8">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
