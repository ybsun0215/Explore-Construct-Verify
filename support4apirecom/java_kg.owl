    <rdf:object rdf:resource="http://example.org/java-kg/individual/sharedmap.containskey"/>
    <prop:relationInstance>execute</prop:relationInstance>
    <prop:sourceText>if two or more threads call the checkthenact() method on the same checkthenactexample object, then two or more threads may execute the if-statement at the same time, evaluate sharedmap.containskey("key") to true, and thus move into the body code block of the if-statement.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5636b45ac33f4a219a0ce7bea9f48a04">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/iterator"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/CONTAINMENT"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/remove"/>
    <prop:relationInstance>has</prop:relationInstance>
    <prop:sourceText>the java iterator interface has a remove() method which lets you remove the element just returned by next() from the underlying collection.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N21e2c824f403473da2ef71cfa920c41e">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/dostop%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/keeprunning"/>
    <prop:relationInstance>has not been called</prop:relationInstance>
    <prop:sourceText>as long as dostop() has not been called the keeprunning() method will return true - meaning the thread executing the run() method will keep running.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nba5ae4e5133149b284b46c275f363b6d">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
