    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/matches"/>
    <prop:relationInstance>return true</prop:relationInstance>
    <prop:sourceText>in other words, if the regular expression matches the beginning of a text but not the whole text, lookingat() will return true, whereas matches() will return false.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N4e89dcd401f643ff99df36722e2673a9">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
