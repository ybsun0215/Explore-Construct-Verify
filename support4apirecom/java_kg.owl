    <rdf:predicate rdf:resource="http://example.org/java-kg/property/CONTAINMENT"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/addlast"/>
    <prop:relationInstance>includes</prop:relationInstance>
    <prop:sourceText>the addlast() method also adds an element to the end (tail) of a java deque.</prop:sourceText>
  </rdf:Description>
