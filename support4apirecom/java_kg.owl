    <prop:relationInstance>corresponds to</prop:relationInstance>
    <prop:sourceText>for instance finest() finer() fine() info() warning() and severe() each corresponds to one of the log levels</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N835ee0344b7c4669ba9e99714ab776a4">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/compareandset%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/equals"/>
    <prop:relationInstance>not equal as in</prop:relationInstance>
    <prop:sourceText>the compareandset() method can compare the reference stored in the atomicreference instance with an expected reference, and if they two references are the same (not equal as in equals() but same as in ==), then a new reference can be set on the atomicreference instance.</prop:sourceText>
  </rdf:Description>
