  <rdf:Description rdf:nodeID="Ne60923c7596144e7bdcc82e6e3392adf">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/comparator"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/IMPLEMENTATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/compare"/>
    <prop:relationInstance>implementation</prop:relationInstance>
    <prop:sourceText>setting the generic type of the comparator implementation to spaceship means that the parameter types of the compare() method can be set to spaceship, and not object as it would have been - if no generic type had been specified ( implements comparator ).</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N87d9f02bee1b48f28e6e12b48c1ca35c">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/cipher.update%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/cipher.dofinal"/>
    <prop:relationInstance>calling</prop:relationInstance>
    <prop:sourceText>you do so by calling the cipher update() or dofinal() methods</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/navigableset">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/java-kg/class/Interface"/>
    <rdfs:label>navigableset</rdfs:label>
    <prop:entityType>Interface</prop:entityType>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/headset"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/polllast"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/pollfirst"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/sortedset"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N49330a27fe1d453d9b9e5a16a81d4f82">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/lower%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/higher"/>
    <prop:relationInstance>opposite</prop:relationInstance>
    <prop:sourceText>the lower() method does the opposite of the higher() method, meaning it returns the highest element that is less than (not equal to) the given parameter.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd9d50caccd60468f86fd94287d623ee7">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/runnable"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/IMPLEMENTATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/execute"/>
    <prop:relationInstance>implementation of</prop:relationInstance>
    <prop:sourceText>second, an anonymous implementation of the runnable interface is passed to the execute() method.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N4191aa83f089425c98be9b24068f8bd8">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/functional%20interface"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/IMPLEMENTATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/run"/>
    <prop:relationInstance>not implemented</prop:relationInstance>
    <prop:sourceText>this is still a functional interface, because only run() is not implemented (abstract).</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5da64e88114a4e3b9d964872f9fcbb85">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/iterator"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/ACCESS"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/queue"/>
    <prop:relationInstance>obtain</prop:relationInstance>
    <prop:sourceText>you can also obtain an iterator from many of the java collection data structures, e.g. a list, set, map, queue, deque or map.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6df5e61f0cb44d5e8b61e50d29532ece">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/touppercase%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/tolowercase"/>
    <prop:relationInstance>convert to uppercase</prop:relationInstance>
    <prop:sourceText>you can convert strings to uppercase and lowercase using the methods touppercase() and tolowercase()</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ndacca62d7cfc434285704459c5b055b5">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/java.util.sortedset"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/CONTAINMENT"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/java.util.set"/>
    <prop:relationInstance>is a subtype of</prop:relationInstance>
    <prop:sourceText>the java sortedset interface, java.util.sortedset, is a subtype of the java.util.set interface.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N09c4f36c466e43ddbfabfafff540fbd8">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
