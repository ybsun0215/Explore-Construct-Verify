  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb7c9798f8d0d4338adb7d08f09061c63">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/interface"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/CONTAINMENT"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/method"/>
    <prop:relationInstance>declared in</prop:relationInstance>
    <prop:sourceText>a class that implements an interface must implement all the methods declared in the interface.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N8be1a6481a034b7fbd5f0323b67ba48c">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/add%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/subtract"/>
    <prop:relationInstance>cannot execute</prop:relationInstance>
    <prop:sourceText>if thread a is executing add() then thread b cannot execute neither add() nor subtract() until thread a has exited add().</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5eaaec37aae1476fb1a18eaf4d629f67">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/add%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/offer"/>
    <prop:relationInstance>differ in behavior</prop:relationInstance>
    <prop:sourceText>the add() and offer() methods differ in how the behave if the queue is full so no more elements can be added</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb2524bc066b1480ba5d2f3a97374fcae">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
