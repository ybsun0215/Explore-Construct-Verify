    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/printf"/>
    <prop:relationInstance>does exactly the same as</prop:relationInstance>
    <prop:sourceText>the java printstream class contains the powerful format() and printf() methods (they do exactly the same but the name printf is more familiar to cprogrammers)</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nbc5086c0b5534b259e10ce7a17541652">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
