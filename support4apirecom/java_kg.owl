  <rdf:Description rdf:nodeID="N8cb2be5b938441cd8cfc2868058f51d2">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/update%28%29"/>
