    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/dofinal"/>
    <prop:relationInstance>calls</prop:relationInstance>
    <prop:sourceText>multiple blocks from a large file, you call the update() once for each block of data, and finish with a call to dofinal() with the last data block.</prop:sourceText>
  </rdf:Description>
