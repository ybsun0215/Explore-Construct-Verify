  </rdf:Description>
  <rdf:Description rdf:nodeID="N98056da2cf7b41b6a0bc5b22aa189c57">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
