    <prop:sourceText>the java collections addall() method can add a variable number of elements to a collection (typically either a list or a set</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ncb1ff785a7cd4f8bb498c9a4062ed3d4">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
