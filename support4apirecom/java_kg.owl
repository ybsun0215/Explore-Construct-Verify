    <rdf:object rdf:resource="http://example.org/java-kg/individual/notify"/>
    <prop:relationInstance>calls</prop:relationInstance>
    <prop:sourceText>for instance, each mywaitnotify3 (example from earlier sections) instance has its own monitorobject instance rather than using the empty string for wait() / notify() calls.</prop:sourceText>
  </rdf:Description>
