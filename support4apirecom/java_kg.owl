    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/digest"/>
    <prop:relationInstance>followed by</prop:relationInstance>
    <prop:sourceText>here is an example of calling update() several times followed by a digest() call:</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ndb45acacbe024887b4ad686370892d74">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/notifyall%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/wait"/>
    <prop:relationInstance>calls</prop:relationInstance>
    <prop:sourceText>once a thread want to notify the waiting threads it calls notifyall() on the object the waiting threads called wait() on.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/unlock%28%29">
