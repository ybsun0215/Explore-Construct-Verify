    <prop:sourceText>a thread cannot call wait(), notify() or notifyall() without holding the lock on the object the method is called on.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Naa2daa1168844f70891d3c9b07e19606">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/process%28%29"/>
