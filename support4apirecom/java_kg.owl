    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/ceilingkey"/>
    <prop:relationInstance>behave like</prop:relationInstance>
    <prop:sourceText>celingentry(), floorentry(), higherentry(), lowerentry(),the navigablemap also has methods to get the entry for a given key, rather than the key itself. these methods behave like the ceilingkey() etc. methods, except they return a map.entry instead of the key object itself.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N216ff53a630c4813a18e8d489a436de4">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/getandincrement%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/getandadd"/>
    <prop:relationInstance>works like</prop:relationInstance>
    <prop:sourceText>the methods getandincrement() and incrementandget() works like getandadd() and addandget() but just add 1 to the value of the atomicinteger.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N96276f7239fe4645a8b872129fe7403b">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/system.err"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/system.out"/>
    <prop:relationInstance>works like</prop:relationInstance>
    <prop:sourceText>system.err works like system.out except it is normally only used to output error texts</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N5c5fbf6c00394c2fa397877d1dee320b">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/tailmap%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/headmap"/>
    <prop:relationInstance>similar to</prop:relationInstance>
    <prop:sourceText>the tailmap() method is similar to the headmap() method, except that tailmap() returns all elements that are equal to or higher than the given parameter element.</prop:sourceText>
  </rdf:Description>
