  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/elements">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/java-kg/class/Method"/>
    <rdfs:label>elements</rdfs:label>
    <prop:entityType>Method</prop:entityType>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N7ad7e8813b0a4b50a6c3d2877499a1f3">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/add%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/offer"/>
    <prop:relationInstance>differ</prop:relationInstance>
    <prop:sourceText>the add() and offer() methods differ in how the behave if the queue is full, so no more elements can be added.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N36fd3bcdffcc4e5cb77710d8fe5525a7">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/dowait%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/donotify"/>
    <prop:relationInstance>communicates_with</prop:relationInstance>
    <prop:sourceText>the waiting thread would call dowait(), and the notifying thread would call donotify().</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd083264bc2fe477f98ed4968ac8544b1">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/iobjectmapping.removegettermapping"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/iobjectmapping.removesettermapping"/>
    <prop:relationInstance>equivalent to</prop:relationInstance>
    <prop:sourceText>just call the iobjectmapping.removegettermapping(string name) or iobjectmapping.removesettermapping(string name) method to do so.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nad70c06e02fd4ddf92be425c6d8ac2ea">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/compareandset%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/equals"/>
    <prop:relationInstance>not equal as in</prop:relationInstance>
    <prop:sourceText>the compareandset() method can compare the reference stored in the atomicreference instance with an expected reference and if they two references are the same (not equal as in equals() but same as in ==) then a new reference can be set on the atomicreference instance</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N04c01baeb6734af0ab587ba61a562514">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/submit%28callable%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/submit%28runnable"/>
    <prop:relationInstance>different</prop:relationInstance>
    <prop:sourceText>the java?executorservice?submit(callable)?method is similar to the?submit(runnable)?method except it takes a?java callable?instead of a?runnable.?</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ne29d1d62362a471191e6db1af6926d6b">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/getandincrement%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/incrementandget"/>
    <prop:relationInstance>works like</prop:relationInstance>
    <prop:sourceText>the methods getandincrement() and incrementandget() works like getandadd() and addandget() but just add 1 to the value of the atomicinteger.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ncbf265261655493787c26283a5c80873">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
