    <rdf:object rdf:resource="http://example.org/java-kg/individual/wait"/>
    <prop:relationInstance>allows</prop:relationInstance>
    <prop:sourceText>object.wait(long timeout) allows other threads to call wait() or notify() too since these methods must be called from inside a synchronized block</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N96eefbeadae949708f2ae3ebcc147d6e">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/start%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/PREFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/group"/>
    <prop:relationInstance>easier to do so with</prop:relationInstance>
    <prop:sourceText>of course you could do this with the start() and end() methods, but it is easier to do so with the group functions.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/contains%28%29">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/java-kg/class/Method"/>
    <rdfs:label>contains()</rdfs:label>
    <prop:entityType>Method</prop:entityType>
    <prop:PREFERENCE rdf:resource="http://example.org/java-kg/individual/equals"/>
    <prop:DIFFERENCE rdf:resource="http://example.org/java-kg/individual/equals"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ne0ebb03a7b644e6a86dc80e9d06f6fab">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/entering%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/exiting"/>
    <prop:relationInstance>called at the beginning</prop:relationInstance>
    <prop:sourceText>for instance ordinary debug trace logging calls to entering() and exiting() would be called at the beginning and end of a method call</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N4d8c1236b28d420b8bab45687c6639f4">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/commit%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/rollback"/>
    <prop:relationInstance>handle</prop:relationInstance>
    <prop:sourceText>exactly how to handle the calls to commit() and or rollback() is covered in the jdbc transactions tutorial</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Na15c99dc05eb445ca18cbd1ad57c2824">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/unlock%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/monitorobject.notify"/>
    <prop:relationInstance>initiates</prop:relationInstance>
    <prop:sourceText>but the thread waiting in the lock() method will not leave that block until the islocked is set to false, and a monitorobject.notify() is executed, as it happens in unlock().</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N3633ae11348b4c61b89ded853772fe85">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
