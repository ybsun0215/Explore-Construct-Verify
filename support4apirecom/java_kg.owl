    <prop:relationInstance>contains</prop:relationInstance>
    <prop:sourceText>the tailmap variable will reference a sortedmap containing all key + value pairs from the navigablemap for the keys "c", "d" and "e", as these keys are considered equal to or larger than the parameter value "c" passed to the tailmap() method.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nf911961819fe4928955efe018a837ecf">
