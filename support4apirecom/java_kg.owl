  </rdf:Description>
  <rdf:Description rdf:nodeID="N11fa4806c80d42ceb138e3ca5e861b4c">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
