    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/peek"/>
    <prop:relationInstance>similar to</prop:relationInstance>
    <prop:sourceText>if the deque is empty, peekfirst() returns null. this is similar to how peek() works, but the method name peekfirst() is a bit more saying about which end of the deque you peek at.</prop:sourceText>
  </rdf:Description>
