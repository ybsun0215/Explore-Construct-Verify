    <rdf:object rdf:resource="http://example.org/java-kg/individual/not"/>
    <prop:relationInstance>returns one matcher</prop:relationInstance>
    <prop:sourceText>the is() method returns one matcher, and the not() method returns another.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb2dc308099d34616ba49586523bbc55e">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
