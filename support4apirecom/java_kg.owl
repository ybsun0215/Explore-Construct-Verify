    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/offer"/>
    <prop:relationInstance>is different from</prop:relationInstance>
    <prop:sourceText>collection.add(e e) is different from the offer() method which will return false if it cannot insert the element</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb1b9f8a2ca7a4485a4787be8be12463d">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
