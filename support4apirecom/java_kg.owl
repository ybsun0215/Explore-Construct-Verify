  <rdf:Description rdf:nodeID="N6531b48febed4bfc8357c288852f9906">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/unlockwrite%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/lockread"/>
    <prop:relationInstance>causing to halt</prop:relationInstance>
    <prop:sourceText>if unlockwrite() was not called from inside a finally-clause, and an exception was thrown from the critical section, the readwritelock would remain write locked forever, causing all threads calling lockread() or lockwrite() on that readwritelock instance to halt indefinately.</prop:sourceText>
  </rdf:Description>
