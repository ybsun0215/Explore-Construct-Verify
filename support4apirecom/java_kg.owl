  <rdf:Description rdf:nodeID="Nc94912a6774040eb91e6952fa3732d4a">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/map.entry"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/CONTAINMENT"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/navigablemap"/>
    <prop:relationInstance>within</prop:relationInstance>
    <prop:sourceText>celingentry(), floorentry(), higherentry(), lowerentry(),the navigablemap also has methods to get the entry for a given key, rather than the key itself. these methods behave like the ceilingkey() etc. methods, except they return a map.entry instead of the key object itself.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/andthen">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
