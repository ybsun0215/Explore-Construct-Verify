    <prop:sourceText>the offerlast() method adds an element to the end (tail) of the deque, just like offer().</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nc1816bdbe446436a8c75b36c189ca33e">
