  <rdf:Description rdf:nodeID="N13faeb1f27b9432c84a54838e0d29bc3">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/getandadd%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/addandget"/>
    <prop:relationInstance>returns the value before addition</prop:relationInstance>
    <prop:sourceText>the getandadd() method does the same as the addandget() method except the getandadd() method returns the value of the element before a value is added to it</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N51ad3697a8a24eb3bb22442e68113b67">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/poll%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/remove"/>
    <prop:relationInstance>differ in behavior if the queue is empty</prop:relationInstance>
    <prop:sourceText>the poll() and remove() both removes the first element in the queue. they differ in how they behave if the queue is empty. the poll() method returns null if the queue is empty. the remove() method throws an exception if the queue is empty.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/addandget">
