    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/wait"/>
    <prop:relationInstance>makes no guarantee about what thread is awakened if multiple thread have called</prop:relationInstance>
    <prop:sourceText>the notify() method makes no guarantee about what thread is awakened if multiple thread have called wait() on the object notify() is called on.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N7e0f8bfe5ac54ba1bda4668777dff7e3">
