    <prop:sourceText>here is an example of obtaining the last key of a sortedmap via its lastkey() method:</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N0ebf95b49bbe4e39ab08ec6e0470af3f">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
