    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/notify"/>
    <prop:relationInstance>must call from inside a synchronized block</prop:relationInstance>
    <prop:sourceText>in other words the calling thread must call wait() or notify() from inside a synchronized block</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Ned8dd79f1eec40b3b701e9adbaa5bc75">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
