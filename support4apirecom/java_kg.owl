  <rdf:Description rdf:nodeID="Nac58a27e30944dd3a4c5a688c925af89">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/getanddecrement%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EQUIVALENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/decrementandget"/>
    <prop:relationInstance>does the same as</prop:relationInstance>
    <prop:sourceText>the getanddecrement() method does the same as the decrementandget() method, except the getanddecrement() method returns the value of the element before it is decremented.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N852a480e3d4c487881f4e96fcf700b21">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/read%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/write"/>
    <prop:relationInstance>blocking</prop:relationInstance>
    <prop:sourceText>the read() and write() calls on the streams are blocking meaning if you try to use the same thread to both read and write this may result in the thread deadlocking itself</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb024f64f19024011b50bfef287f21a60">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/lock%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/unlock"/>
    <prop:relationInstance>block</prop:relationInstance>
    <prop:sourceText>if a thread calls lock() twice without calling unlock() in between, the second call to lock() will block.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N53c1999cbebf45d188dd6e3acac5f3cf">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/hashcode%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/DIFFERENCE"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/equals"/>
    <prop:relationInstance>distinct role</prop:relationInstance>
    <prop:sourceText>the methods hashcode() and equals() play a distinct role in the objects you insert into java collections.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/java-kg/individual/collection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://example.org/java-kg/class/Interface"/>
    <rdfs:label>collection</rdfs:label>
    <prop:entityType>Interface</prop:entityType>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/list"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/set"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/iterator"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/contains"/>
    <prop:CONTAINMENT rdf:resource="http://example.org/java-kg/individual/containsall"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N35e369b32dae4ba99292d9a910a3a0c7">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/notify%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/EXECUTION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/wait"/>
    <prop:relationInstance>calls</prop:relationInstance>
    <prop:sourceText>when the notifying thread wants to notify a specific waiting thread it will call notify() on the object this specific thread has called wait() on.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nb27f49b3802c4b16b1cb832a5c25039d">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/release%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/LIMITATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/take"/>
    <prop:relationInstance>be allowed to deliver its signal</prop:relationInstance>
    <prop:sourceText>not until a thread has called release() will the thread calling take() be allowed to deliver its signal</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N978962d25d714cf19adf6ef8dc264f38">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/unlock%28%29"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/COLLABORATION"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/wait"/>
    <prop:relationInstance>notifies</prop:relationInstance>
    <prop:sourceText>executing unlock() sets islocked back to false and notifies (awakens) one of the threads waiting in the wait() call in the lock() method if any</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N817d2ec42cbb430f8901f40e0ed45c87">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
    <rdf:subject rdf:resource="http://example.org/java-kg/individual/interface"/>
    <rdf:predicate rdf:resource="http://example.org/java-kg/property/CONTAINMENT"/>
    <rdf:object rdf:resource="http://example.org/java-kg/individual/produce"/>
    <prop:relationInstance>contains</prop:relationInstance>
    <prop:sourceText>this interface represents an interface which contains a single method called produce() which can produce a single object.</prop:sourceText>
  </rdf:Description>
