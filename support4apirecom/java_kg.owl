    <rdf:object rdf:resource="http://example.org/java-kg/individual/verify"/>
    <prop:relationInstance>call</prop:relationInstance>
    <prop:sourceText>once initialized into verification mode, you call the update() method with the data the signature is signing, and finish with a call to verify() which returns true or false depending on whether the signature could be verified or not.</prop:sourceText>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N849656a7d7114f1785cb1833c21a4f25">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement"/>
